@model IEnumerable<SparePartsManagement.Models.Coupon>
@{
    ViewData["Title"] = "Quản lý Mã Khuyến Mãi (Coupons)";
}

<div class="card border-0 shadow-sm rounded-4 h-100">
    <div class="card-header bg-white border-bottom p-4 d-flex justify-content-between align-items-center">
        <h5 class="fw-bold m-0"><i class="fas fa-ticket-alt text-danger me-2"></i> DANH SÁCH MÃ GIẢM GIÁ</h5>
        <button class="btn btn-danger btn-sm rounded-pill fw-bold" data-bs-toggle="modal" data-bs-target="#couponModal"><i class="fas fa-plus"></i> Tạo Coupon</button>
    </div>
    <div class="card-body p-0">
        <table class="table align-middle mb-0 table-hover">
            <thead class="bg-light">
                <tr class="text-muted small text-uppercase fw-bold">
                    <th class="ps-4">Mã CODE</th>
                    <th>Mức giảm</th>
                    <th>Hạn sử dụng</th>
                    <th>Trạng thái</th>
                    <th class="pe-4 text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any()) {
                    foreach (var cp in Model) {
                        <tr>
                            <td class="ps-4 py-3">
                                <span class="badge bg-light text-dark border fw-black px-3 py-2 fs-6 shadow-sm">@cp.Code</span>
                            </td>
                            <td class="fw-bold text-success">- @cp.DiscountPercentage%</td>
                            <td class="text-muted small">
                                @(cp.ExpiryDate.HasValue ? cp.ExpiryDate.Value.ToString("dd/MM/yyyy") : "Vô thời hạn")
                            </td>
                            <td>
                                <form asp-action="ToggleStatus" method="post" class="m-0">
                                    <input type="hidden" name="id" value="@cp.CouponId" />
                                    <div class="form-check form-switch m-0 pt-1">
                                        <input class="form-check-input" type="checkbox" role="switch" onchange="this.form.submit()" @(cp.IsActive ? "checked" : "") style="cursor: pointer;">
                                        <label class="form-check-label small fw-bold @(cp.IsActive ? "text-primary" : "text-muted")">@(cp.IsActive ? "Kích hoạt" : "Vô hiệu")</label>
                                    </div>
                                </form>
                            </td>
                            <td class="pe-4 text-end">
                                <form asp-action="Delete" method="post" onsubmit="return confirm('Xoá mã giảm giá rủi ro làm mất lịch sử. Đồng ý?');">
                                    <input type="hidden" name="id" value="@cp.CouponId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger btn-circle shadow-sm" style="width: 35px; height: 35px; border-radius: 50%;"><i class="fas fa-trash-alt"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                } else {
                    <tr><td colspan="5" class="text-center py-5 text-muted">Chưa có mã khuyến mãi nào được tạo.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Create -->
<div class="modal fade" id="couponModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <form asp-action="Create" method="post">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">Tạo Mã Coupon</h5>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body py-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Mã Code (Tùy chọn) *</label>
                        <input type="text" name="Code" class="form-control text-uppercase" placeholder="Để trống tự tạo ngẫu nhiên (VD: TET2024)" />
                    </div>
                    <div class="row q-4">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold small text-muted">Mức giảm (%) *</label>
                            <input type="number" name="DiscountPercentage" class="form-control" required min="1" max="100" placeholder="vd: 15" />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold small text-muted">Ngày hết hạn</label>
                            <input type="date" name="ExpiryDate" class="form-control" />
                        </div>
                    </div>
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked>
                        <label class="form-check-label fw-bold small text-muted">Kích hoạt sử dụng ngay</label>
                    </div>
                </div>
                <div class="modal-footer bg-light border-top-0 rounded-bottom-4">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm">Tạo mới</button>
                </div>
            </form>
        </div>
    </div>
</div>
