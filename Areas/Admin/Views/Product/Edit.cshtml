@model SparePartsManagement.Models.Product
@{
    ViewData["Title"] = "Cập nhật Sản Phẩm";
    var categories = ViewBag.Categories as IEnumerable<SparePartsManagement.Models.Category>;
    var brands = ViewBag.Brands as IEnumerable<SparePartsManagement.Models.Brand>;
}

<div class="mb-4">
    <a href="/Admin/Products/Index" class="btn btn-outline-secondary rounded-pill btn-sm fw-bold"><i class="fas fa-arrow-left me-1"></i> Quay lại danh sách</a>
</div>

<h3 class="fw-bold mb-4 text-dark"><i class="fas fa-edit text-primary me-2"></i> @ViewData["Title"]: @Model.Name</h3>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4 p-md-5">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="ProductId" />
            <input type="hidden" asp-for="CreatedAt" />
            <input type="hidden" asp-for="StarRating" />

            <div class="row g-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold small text-muted">Tên phụ tùng *</label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-muted">Danh mục *</label>
                    <select asp-for="CategoryId" class="form-select" required>
                        @if(categories != null)
                        {
                            foreach (var cat in categories)
                            {
                                <option value="@cat.CategoryId" selected="@(cat.CategoryId == Model.CategoryId ? "selected" : null)">@cat.Name</option>
                            }
                        }
                    </select>
                </div>
                
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-muted">Hãng xe *</label>
                    <select asp-for="BrandId" class="form-select" required>
                        @if(brands != null)
                        {
                            foreach (var brand in brands)
                            {
                                <option value="@brand.BrandId" selected="@(brand.BrandId == Model.BrandId ? "selected" : null)">@brand.Name</option>
                            }
                        }
                    </select>
                </div>
                
                <div class="col-md-4">
                    <label class="form-label fw-bold small text-muted">Dòng xe tương thích</label>
                    <input asp-for="CarModel" class="form-control" />
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold small text-muted">Giá tiền (VND) *</label>
                    <div class="input-group">
                        <input asp-for="Price" type="number" min="0" step="1000" class="form-control" required />
                        <span class="input-group-text bg-light fw-bold">đ</span>
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold small text-muted">Số lượng Tồn kho *</label>
                    <input asp-for="StockQuantity" type="number" min="0" class="form-control" required />
                </div>

                <div class="col-md-12">
                    <label class="form-label fw-bold small text-muted">Thay đổi hình ảnh (Kéo thả hoặc Chọn tệp)</label>
                    <div id="drop-zone" class="border-2 border-dashed rounded-4 p-4 text-center bg-light position-relative overflow-hidden" style="cursor: pointer; transition: all 0.3s; border-color: #dee2e6 !important;">
                        <div id="preview-container" class="@(string.IsNullOrEmpty(Model.ImageUrl) ? "d-none" : "")">
                            <img id="image-preview" src="@(Model.ImageUrl ?? "#")" class="img-fluid rounded-3 mb-3 shadow-sm" style="max-height: 200px;" />
                            <div id="upload-status" class="small fw-bold text-success d-none"><i class="fas fa-check-circle me-1"></i> Tệp mới đã chọn!</div>
                            <button type="button" class="btn btn-sm btn-outline-danger rounded-pill mt-2" onclick="resetFile()"><i class="fas fa-times me-1"></i> Xóa ảnh</button>
                        </div>
                        <div id="upload-prompt" class="@(string.IsNullOrEmpty(Model.ImageUrl) ? "" : "d-none")">
                            <i class="fas fa-cloud-upload-alt fa-3x text-primary opacity-50 mb-3"></i>
                            <p class="mb-1 fw-bold">Kéo và thả tệp ảnh mới vào đây</p>
                            <p class="text-muted small">Hoặc click để chọn một tệp thay thế</p>
                        </div>
                        <input type="file" name="imageFile" id="imageFile" class="position-absolute top-0 start-0 w-100 h-100 opacity-0" style="cursor: pointer;" accept="image/*" />
                        <input type="hidden" asp-for="ImageUrl" id="ImageUrlHidden" />
                    </div>
                    <div class="mt-2">
                         <label class="form-label fw-bold small text-muted mt-2">Hoặc cập nhật URL hình ảnh trực tiếp:</label>
                         <input asp-for="ImageUrl" id="ImageUrlInput" class="form-control" placeholder="https://..." oninput="updatePreviewFromUrl(this.value)" />
                    </div>
                </div>

                <div class="col-md-12">
                    <label class="form-label fw-bold small text-muted">Mô tả sản phẩm</label>
                    <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                </div>

                <div class="col-md-12">
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" type="checkbox" role="switch" id="IsHot" name="IsHot" value="true" @(Model.IsHot ? "checked" : "")>
                        <label class="form-check-label fw-bold ms-2" for="IsHot">Đánh dấu sản phẩm HOT / MỚI</label>
                    </div>
                </div>
            </div>
            
            <hr class="my-5" />
            
            <div class="text-end">
                <button type="submit" class="btn btn-primary px-5 py-2 rounded-pill fw-bold shadow-lg"><i class="fas fa-save me-2"></i> LƯU THAY ĐỔI</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const fileInput = document.getElementById('imageFile');
        const dropZone = document.getElementById('drop-zone');
        const uploadPrompt = document.getElementById('upload-prompt');
        const previewContainer = document.getElementById('preview-container');
        const imagePreview = document.getElementById('image-preview');
        const uploadStatus = document.getElementById('upload-status');
        const imageUrlInput = document.getElementById('ImageUrlInput');
        const imageUrlHidden = document.getElementById('ImageUrlHidden');

        fileInput.addEventListener('change', function(e) {
            handleFiles(this.files);
        });

        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.style.borderColor = "#007bff";
            dropZone.classList.add('bg-white');
        });

        dropZone.addEventListener('dragleave', () => {
            dropZone.style.borderColor = "#dee2e6";
            dropZone.classList.remove('bg-white');
        });

        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.style.borderColor = "#dee2e6";
            dropZone.classList.remove('bg-white');
            const dt = e.dataTransfer;
            const files = dt.files;
            fileInput.files = files;
            handleFiles(files);
        });

        function handleFiles(files) {
            if (files.length > 0) {
                const file = files[0];
                if (file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        imagePreview.src = e.target.result;
                        previewContainer.classList.remove('d-none');
                        uploadPrompt.classList.add('d-none');
                        uploadStatus.classList.remove('d-none');
                        imageUrlInput.value = ""; // Clear URL field if local file chosen
                        imageUrlHidden.value = ""; // Clear current DB path so we don't restore it
                    }
                    reader.readAsDataURL(file);
                }
            }
        }

        function resetFile() {
            fileInput.value = "";
            imagePreview.src = "#";
            previewContainer.classList.add('d-none');
            uploadPrompt.classList.remove('d-none');
            uploadStatus.classList.add('d-none');
            imageUrlInput.value = "";
            imageUrlHidden.value = "";
        }

        function updatePreviewFromUrl(url) {
            if (url && url.length > 5) {
                imagePreview.src = url;
                previewContainer.classList.remove('d-none');
                uploadPrompt.classList.add('d-none');
                uploadStatus.classList.add('d-none'); // URL is not a "new file upload" from local
                fileInput.value = ""; 
            } else if (!fileInput.files.length) {
                resetFile();
            }
        }
    </script>
    <style>
        .border-dashed { border-style: dashed !important; }
    </style>
}
