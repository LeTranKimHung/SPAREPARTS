@model IEnumerable<SparePartsManagement.Models.Product>
@{
    ViewData["Title"] = "Quản lý Phụ tùng";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
    <h2 class="fw-bold mb-0 text-dark"><i class="fas fa-boxes text-danger me-2"></i> @ViewData["Title"]</h2>
    <div>
        <a href="/Admin/CategoryBrand/Index" class="btn btn-outline-secondary rounded-pill fw-bold me-2"><i class="fas fa-tags me-1"></i> Quản lý Nhãn/Hãng</a>
        <a href="/Admin/Products/Create" class="btn btn-danger rounded-pill fw-bold shadow-sm"><i class="fas fa-plus-circle me-1"></i> Nhập sản phẩm mới</a>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-muted small text-uppercase fw-bold">
                <tr>
                    <th class="ps-4 py-3">ID</th>
                    <th class="py-3">Hình ảnh</th>
                    <th class="py-3">Tên sản phẩm</th>
                    <th class="py-3">Danh mục / Hãng</th>
                    <th class="py-3">Tồn kho / Giá</th>
                    <th class="pe-4 py-3 text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-muted">#@item.ProductId</td>
                            <td>
                                <div class="bg-light rounded p-2" style="width: 60px; height: 60px;">
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://images.unsplash.com/photo-1541443131876-44b035dd1c51?q=80" : item.ImageUrl)" class="w-100 h-100 object-fit-contain" alt="@item.Name" style="object-fit: contain;">
                                </div>
                            </td>
                            <td>
                                <h6 class="fw-bold mb-1"><a href="/PublicProduct/Details/@item.ProductId" target="_blank" class="text-dark text-decoration-none">@item.Name</a></h6>
                                @if (item.IsHot) { <span class="badge bg-danger rounded-pill px-2" style="font-size: 0.65rem;">MỚI / HOT</span> }
                            </td>
                            <td>
                                <div class="small fw-bold text-primary">@item.Category?.Name</div>
                                <div class="small text-muted">@item.Brand?.Name</div>
                            </td>
                            <td>
                                <div class="fw-bold @(item.StockQuantity > 0 ? "text-success" : "text-danger")">@item.StockQuantity (sp)</div>
                                <div class="small fw-bold text-dark mt-1">@item.Price.ToString("N0") đ</div>
                            </td>
                            <td class="pe-4 text-end">
                                <a href="/Admin/Products/Edit/@item.ProductId" class="btn btn-sm btn-outline-primary rounded-pill px-3"><i class="fas fa-edit me-1"></i> Sửa</a>
                                
                                <form asp-action="Delete" asp-route-id="@item.ProductId" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này không?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3"><i class="fas fa-trash-alt me-1"></i> Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="fas fa-box-open fa-3x mb-3 opacity-25"></i>
                            <p class="mb-0">Chưa có sản phẩm nào. Hãy tạo sản phẩm mới!</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
