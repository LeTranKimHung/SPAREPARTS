@model IEnumerable<SparePartsManagement.Models.Order>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
    <h2 class="fw-bold mb-0 text-dark"><i class="fas fa-shopping-cart text-primary me-2"></i> @ViewData["Title"]</h2>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase fw-bold">
                    <tr>
                        <th class="ps-4 py-3">Mã đơn #</th>
                        <th class="py-3">Khách hàng</th>
                        <th class="py-3">Ngày đặt</th>
                        <th class="py-3">Tổng tiền</th>
                        <th class="py-3">Trạng thái (Cập nhật)</th>
                        <th class="pe-4 py-3 text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-primary">#@order.OrderId</td>
                                <td>
                                    <h6 class="fw-bold mb-1">@order.CustomerName</h6>
                                    <div class="small fw-bold text-muted"><i class="fas fa-phone-alt me-1"></i> @order.Phone</div>
                                </td>
                                <td>
                                    <div class="text-muted">@order.OrderDate.ToString("dd/MM/yyyy")</div>
                                    <div class="small fw-bold text-dark">@order.OrderDate.ToString("HH:mm")</div>
                                </td>
                                <td class="fw-bold text-danger">@order.TotalAmount.ToString("N0") đ</td>
                                <td>
                                    <form asp-action="UpdateStatus" method="post" class="d-flex gap-2 align-items-center m-0">
                                        <input type="hidden" name="id" value="@order.OrderId" />
                                        <select name="status" class="form-select form-select-sm fw-bold border-0 bg-light shadow-none" style="width: 150px;" onchange="this.form.submit()">
                                            @if(order.Status == 0) { <option value="0" selected>Chờ xác nhận</option> } else { <option value="0">Chờ xác nhận</option> }
                                            @if(order.Status == 1) { <option value="1" selected>Đang giao</option> } else { <option value="1">Đang giao</option> }
                                            @if(order.Status == 2) { <option value="2" selected>Đã hoàn thành</option> } else { <option value="2">Đã hoàn thành</option> }
                                            @if(order.Status == 3) { <option value="3" selected>Đã hủy</option> } else { <option value="3">Đã hủy</option> }
                                        </select>
                                    </form>
                                </td>
                                <td class="pe-4 text-end">
                                    <a href="/Admin/Orders/Details/@order.OrderId" class="btn btn-sm btn-outline-dark rounded-pill px-3"><i class="fas fa-eye me-1"></i> Xem</a>
                                    
                                    <form asp-action="Delete" asp-route-id="@order.OrderId" method="post" class="d-inline" onsubmit="return confirm('Hủy và xóa đơn hàng vĩnh viễn?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3"><i class="fas fa-trash-alt me-1"></i> Xóa</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fas fa-clipboard-list fa-3x mb-3 opacity-25"></i>
                                <p class="mb-0">Chưa có giao dịch đơn hàng nào.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
