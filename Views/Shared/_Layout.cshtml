@using Microsoft.AspNetCore.Http
@using SparePartsManagement.Helpers
@using SparePartsManagement.ViewModels
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Phụ Tùng Xe Chính Hãng</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header style="position: relative; z-index: 1050;">
        <nav class="navbar navbar-expand-lg">
            <div class="container-xxl">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-tools me-2 text-white"></i> SPARE <span class="text-danger">PARTS</span>
                </a>
                <button class="navbar-toggler text-white" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="PublicProduct" asp-action="Index">Sản phẩm</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Home/About">Giới thiệu</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Contact">Liên hệ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Service">Đăng ký bảo dưỡng</a>
                        </li>
                    </ul>

                    <!-- 🔍 Quick Search Bar -->
                    <form class="d-flex ms-auto me-lg-4 my-2 my-lg-0 position-relative" style="max-width: 200px; width: 100%;" action="/PublicProduct" method="get">
                        <input name="keyword" class="form-control bg-white bg-opacity-10 border-0 rounded-pill text-white px-4 py-2 small shadow-none" type="search" placeholder="Tìm phụ tùng..." aria-label="Search" style="border: 1px solid rgba(255,255,255,0.1) !important;">
                        <button class="btn position-absolute end-0 top-0 h-100 text-white-50 border-0 px-3" type="submit"><i class="fas fa-search small"></i></button>
                    </form>

                    <div class="d-flex align-items-center">
                        <a href="/Cart" class="nav-link position-relative me-3 text-white">
                            <i class="fas fa-shopping-cart fa-lg"></i>
                            @{
                                var session = HttpContextAccessor.HttpContext?.Session;
                                List<CartItem>? cart = null;
                                if (session != null)
                                {
                                    cart = session.GetSession<List<CartItem>>("CartItems");
                                }
                                var count = cart?.Sum(i => i.Quantity) ?? 0;
                            }
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white">@count</span>
                        </a>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="dropdown">
                                <a class="nav-link dropdown-toggle btn btn-danger text-white rounded-pill px-4 py-2 shadow-lg fw-bold border-0" href="#" id="userDropdown" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle me-2"></i> @User.Identity.Name?.Split('@')[0].ToUpper()
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 mt-2 overflow-hidden">
                                    <li class="bg-light p-3 border-bottom">
                                        <div class="small text-muted fw-bold">TÀI KHOẢN ĐANG DÙNG:</div>
                                        <div class="small fw-bold text-dark text-truncate">@User.Identity.Name</div>
                                    </li>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><a class="dropdown-item py-2 fw-bold text-primary" href="/Admin/Products/Index"><i class="fas fa-user-shield me-2"></i>QUẢN TRỊ VIÊN</a></li>
                                        <li><hr class="dropdown-divider m-0"></li>
                                    }
                                    <li><a class="dropdown-item py-2" href="/Account/Profile"><i class="fas fa-id-card me-2"></i>Hồ sơ cá nhân</a></li>
                                    <li><a class="dropdown-item py-2" href="/Home/MyBookings"><i class="fas fa-tools me-2 text-warning"></i>Lịch bảo dưỡng</a></li>
                                    <li><a class="dropdown-item py-2" href="/Wishlist"><i class="fas fa-heart me-2 text-danger"></i>Sản phẩm yêu thích</a></li>
                                    <li><a class="dropdown-item py-2" href="/Cart/TrackOrder"><i class="fas fa-shipping-fast me-2"></i>Đơn hàng đã đặt</a></li>
                                    <li><hr class="dropdown-divider m-0"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item py-2 text-danger fw-bold"><i class="fas fa-sign-out-alt me-2"></i>ĐĂNG XUẤT</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a href="/Account/Login" class="btn btn-outline-light btn-sm rounded-pill px-4 me-2">Đăng nhập</a>
                            <a href="/Account/Register" class="btn btn-danger btn-sm rounded-pill px-4">Đăng ký</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="bg-dark text-white py-5 mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5 class="fw-bold mb-3">SPARE PARTS STORE</h5>
                    <p class="text-white-50 small">Cung cấp phụ tùng xe chính hãng, chất lượng cao, giá thành cạnh tranh nhất thị trường Việt Nam.</p>
                </div>
                <div class="col-md-4 mb-4">
                    <h5 class="fw-bold mb-3">Liên hệ</h5>
                    <div class="text-white-50 small">
                        <p><i class="fas fa-map-marker-alt me-2"></i> 123 Đường Láng, Đống Đa, Hà Nội</p>
                        <p><i class="fas fa-phone me-2"></i> 0987.654.321</p>
                    </div>
                </div>
                <div class="col-md-4 mb-4 text-md-end">
                    <h5 class="fw-bold mb-3">Mạng xã hội</h5>
                    <div class="d-flex justify-content-md-end gap-3 text-white">
                        <i class="fab fa-facebook-f fa-lg"></i>
                        <i class="fab fa-instagram fa-lg"></i>
                        <i class="fab fa-youtube fa-lg"></i>
                    </div>
                </div>
            </div>
            <hr class="border-secondary">
            <div class="text-center text-white-50 small mt-4">
                &copy; 2026 - SparePartsManagement - <a href="#" class="text-white-50 text-decoration-none">Chính sách bảo mật</a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
