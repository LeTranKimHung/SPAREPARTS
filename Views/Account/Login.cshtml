@model SparePartsManagement.Controllers.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container my-5 py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white text-center py-4 border-0">
                    <h3 class="fw-bold m-0"><i class="fas fa-lock me-2 text-danger"></i> ĐĂNG NHẬP</h3>
                    <p class="small m-0 text-white-50 mt-1">Chào mừng bạn trở lại với hệ thống</p>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4 small"></div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-bold small text-muted text-uppercase">Địa chỉ Email</label>
                            <div class="input-group">
                                <span class="input-group-text border-0 bg-light py-3 px-3 rounded-start-3"><i class="fas fa-envelope"></i></span>
                                <input asp-for="Email" class="form-control border-0 bg-light py-3 px-4 rounded-end-3 shadow-none" placeholder="name@example.com">
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-bold small text-muted text-uppercase">Mật khẩu</label>
                            <div class="input-group">
                                <span class="input-group-text border-0 bg-light py-3 px-3 rounded-start-3"><i class="fas fa-key"></i></span>
                                <input asp-for="Password" type="password" class="form-control border-0 bg-light py-3 px-4 rounded-end-3 shadow-none" placeholder="******">
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-4 d-flex justify-content-between align-items-center">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" asp-for="RememberMe">
                                <label class="form-check-label small" asp-for="RememberMe">Ghi nhớ tôi</label>
                            </div>
                            <a href="#" class="text-danger small text-decoration-none fw-bold">Quên mật khẩu?</a>
                        </div>

                        <button type="submit" class="btn btn-danger w-100 rounded-pill py-3 fw-bold shadow-lg mb-4">
                            ĐĂNG NHẬP NGAY <i class="fas fa-arrow-right ms-2"></i>
                        </button>

                        <div class="text-center">
                            <p class="text-muted small">Chưa có tài khoản? <a asp-action="Register" class="text-dark fw-bold text-decoration-none">Đăng ký tại đây</a></p>
                        </div>
                    </form>
                </div>
            </div>         
        </div>
    </div>
</div>
