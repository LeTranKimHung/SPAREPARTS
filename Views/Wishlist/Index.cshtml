@model IEnumerable<SparePartsManagement.ViewModels.CartItem>

@{
    ViewData["Title"] = "Danh sách yêu thích";
}

<div class="container my-5 py-5">
    <div class="row mb-5">
        <div class="col text-center">
            <h2 class="fw-bold m-0"><i class="fas fa-heart text-danger me-3"></i>DANH SÁCH YÊU THÍCH</h2>
            <p class="text-muted small mt-2">Lưu lại những phụ tùng bạn quan tâm và mua sau</p>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                        <div class="position-relative">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://images.unsplash.com/photo-1541443131876-44b035dd1c51?q=80" : item.ImageUrl)" class="card-img-top" alt="@item.ProductName" style="height: 200px; object-fit: cover;">
                            <form asp-action="Remove" asp-route-id="@item.ProductId" method="post" class="position-absolute top-0 end-0 m-3">
                                <button type="submit" class="btn btn-light btn-sm rounded-circle shadow-sm text-danger" style="width: 35px; height: 35px;"><i class="fas fa-trash"></i></button>
                            </form>
                        </div>
                        <div class="card-body p-4 text-center">
                            <h6 class="fw-bold mb-2">@item.ProductName</h6>
                            <h5 class="text-danger fw-bold mb-4">@item.Price.ToString("N0") đ</h5>
                            
                            <div class="d-grid gap-2">
                                <a href="/PublicProduct/Details/@item.ProductId" class="btn btn-outline-dark rounded-pill fw-bold small">XEM CHI TIẾT</a>
                                <form asp-controller="Cart" asp-action="Add" asp-route-id="@item.ProductId" method="post">
                                    <button type="submit" class="btn btn-danger w-100 rounded-pill fw-bold small">
                                        <i class="fas fa-cart-plus me-2"></i>CHO VÀO GIỎ
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="mb-4">
                <i class="far fa-heart fa-5x text-muted opacity-25"></i>
            </div>
            <h4 class="fw-bold text-muted">Chưa có sản phẩm yêu thích nào</h4>
            <p class="text-muted small mb-4">Hãy thả tim cho những phụ tùng bạn ưng ý nhé!</p>
            <a href="/PublicProduct" class="btn btn-danger rounded-pill px-5 fw-bold shadow-lg py-3">KHÁM PHÁ NGAY</a>
        </div>
    }
</div>
