@model SparePartsManagement.Models.ServiceBooking
@{
    ViewData["Title"] = "Đăng ký Bảo dưỡng";
}

<header class="position-relative d-flex align-items-center justify-content-center text-center overflow-hidden" style="min-height: 40vh; background-image: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.8)), url('https://images.unsplash.com/photo-1621252178923-d8cba9aef11f?q=80&w=2000&auto=format&fit=crop'); background-size: cover; background-position: center; background-attachment: fixed; color: #fff;">
    <div class="container px-4 z-index-2 position-relative" style="padding-top: 80px;">
        <h1 class="display-4 fw-black mb-3 text-uppercase" style="letter-spacing: -1px; font-weight: 900;">
            ĐẶT LỊCH BẢO DƯỠNG XE
        </h1>
        <p class="lead mx-auto text-white-50" style="max-width: 600px; font-weight: 400;">
            Chăm sóc toàn diện, chuẩn hãng. Khắc phục triệt để mọi lỗi hệ thống với đội ngũ kỹ thuật viên tay nghề cao.
        </p>
    </div>
</header>

<div class="container my-5 py-5">
    <div class="row g-5">
        <!-- Service Description -->
        <div class="col-lg-5 order-lg-2">
            <span class="text-danger fw-bold letter-spacing-1 small text-uppercase">Dịch vụ Gara</span>
            <h2 class="fw-black mb-4 mt-2 display-6 text-dark">LÝ DO BẠN NÊN ĐỘ CỨNG XE TẠI ĐÂY</h2>
            <div class="bg-danger mb-5" style="height: 4px; width: 60px; border-radius: 2px;"></div>
            
            <div class="d-flex mb-4 hover-lift transition-all">
                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-4 shadow-sm" style="width: 60px; height: 60px; min-width: 60px;">
                    <i class="fas fa-tools fa-lg text-danger"></i>
                </div>
                <div>
                    <h5 class="fw-bold text-dark mb-2">Thay thế linh kiện chính hãng</h5>
                    <p class="text-muted small">Quy trình thay nhớt, lọc gió, ắc quy đúng tiêu chuẩn. Nguồn gốc rõ ràng.</p>
                </div>
            </div>
            
            <div class="d-flex mb-4 hover-lift transition-all">
                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-4 shadow-sm" style="width: 60px; height: 60px; min-width: 60px;">
                    <i class="fas fa-search-dollar fa-lg text-warning"></i>
                </div>
                <div>
                    <h5 class="fw-bold text-dark mb-2">Chẩn đoán lỗi hệ thống miễn phí</h5>
                    <p class="text-muted small">Sử dụng máy quét OBD thế hệ 2026, đọc chính xác thông số động cơ và các cảnh báo.</p>
                </div>
            </div>

            <div class="d-flex mb-4 hover-lift transition-all">
                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-4 shadow-sm" style="width: 60px; height: 60px; min-width: 60px;">
                    <i class="fas fa-clock fa-lg text-primary"></i>
                </div>
                <div>
                    <h5 class="fw-bold text-dark mb-2">Tiết kiệm Thời gian chờ</h5>
                    <p class="text-muted small">Khách đặt lịch trước sẽ được ưu tiên nhận xe làm ngay, không phải xếp hàng trong garage.</p>
                </div>
            </div>

            <div class="alert alert-danger rounded-4 mt-5 p-4 border-0">
                <h6 class="fw-bold"><i class="fas fa-gift me-2"></i>Tặng kèm gói vệ sinh máy:</h6>
                <p class="small mb-0 mt-2">Đăng ký dịch vụ Gói Toàn Diện ngay tuần này để được Xịt dọn khoang máy công nghệ hơi nước nóng miễn phí.</p>
            </div>
        </div>

        <!-- Appointment Form -->
        <div class="col-lg-7 order-lg-1">
            <div class="card border-0 shadow-lg rounded-5 p-5 bg-white h-100">
                <h3 class="fw-bold text-dark mb-4">Mẫu đăng ký Lịch Hẹn</h3>
                <p class="text-muted small mb-4 pb-3 border-bottom">Vui lòng điền thông tin chi tiết để chúng tôi phân công thợ sửa chữa chuyên môn phù hợp nhất cho xe của bạn.</p>
                
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success rounded-3 mb-4">
                        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger rounded-3 mb-4">
                        <i class="fas fa-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
                    </div>
                }

                <form asp-action="BookService" method="post">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label text-muted fw-bold small">Họ và Tên *</label>
                            <input asp-for="FullName" type="text" class="form-control bg-light border-0 shadow-none px-4 py-3 rounded-3" placeholder="Nguyễn Văn A" required>
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted fw-bold small">Số điện thoại liên hệ *</label>
                            <input asp-for="PhoneNumber" type="tel" class="form-control bg-light border-0 shadow-none px-4 py-3 rounded-3" placeholder="0987xxx" required>
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label text-muted fw-bold small">Thương hiệu / Dòng xe *</label>
                            <input asp-for="CarModel" type="text" class="form-control bg-light border-0 shadow-none px-4 py-3 rounded-3" placeholder="Ví dụ: Honda City 2021" required>
                            <span asp-validation-for="CarModel" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted fw-bold small">Biển số xe (Tùy chọn)</label>
                            <input asp-for="LicensePlate" type="text" class="form-control bg-light border-0 shadow-none px-4 py-3 rounded-3" placeholder="30G-XXXXX">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-muted fw-bold small">Ngày hẹn muốn đến *</label>
                            <input asp-for="AppointmentDate" type="date" class="form-control bg-light border-0 shadow-none px-4 py-3 rounded-3" required min="@DateTime.Now.ToString("yyyy-MM-dd")">
                            <span asp-validation-for="AppointmentDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted fw-bold small">Khung giờ ước tính *</label>
                            <select asp-for="TimeSlot" class="form-select bg-light border-0 shadow-none px-4 py-3 rounded-3" required>
                                <option value="" disabled selected>Chọn giờ bảo dưỡng</option>
                                <option value="08:00 - 10:00">08:00 - 10:00 (Sáng)</option>
                                <option value="10:00 - 12:00">10:00 - 12:00 (Sáng)</option>
                                <option value="13:30 - 15:30">13:30 - 15:30 (Chiều)</option>
                                <option value="15:30 - 17:30">15:30 - 17:30 (Chiều)</option>
                            </select>
                            <span asp-validation-for="TimeSlot" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-12">
                            <label class="form-label text-muted fw-bold small">Dịch vụ yêu cầu / Triệu chứng lỗi *</label>
                            <textarea asp-for="ServiceDetails" class="form-control bg-light border-0 shadow-none px-4 py-3 rounded-3" rows="4" placeholder="Ví dụ: Thay lốp, Kiểm tra bình ắc quy, hoặc 'Xe đi bị giật, phanh ăn không đều'..." required></textarea>
                            <span asp-validation-for="ServiceDetails" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-12 mt-4 pt-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill px-5 fw-bold w-100 hover-lift shadow-danger-lg">ĐẶT LỊCH NGAY</button>
                            <p class="text-center text-muted small mt-3">Chúng tôi sẽ gọi lại cho bạn trong vòng 15 phút để xác nhận.</p>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
