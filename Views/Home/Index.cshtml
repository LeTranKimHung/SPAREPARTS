@model IEnumerable<SparePartsManagement.Models.Product>

@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Minimalist Full-Screen Hero Section -->
<header class="hero-section d-flex align-items-center justify-content-center text-center" style="min-height: 100vh; background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?q=80&w=2000&auto=format&fit=crop'); background-size: cover; background-position: center; background-attachment: fixed; color: #fff; padding-top: 80px;">
    <div class="container px-4">
        <h1 class="display-3 fw-bold mb-4" style="letter-spacing: -1px; color: #fff;">
            PHỤ TÙNG XE CHÍNH HÃNG
        </h1>
        <p class="lead mb-5 mx-auto" style="max-width: 600px; font-weight: 400; color: rgba(255,255,255,0.8);">
            Hệ thống phân phối đa dạng mẫu mã từ các thương hiệu hàng đầu thế giới. Giao hàng hỏa tốc toàn quốc.
        </p>
        <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
            <a href="/PublicProduct" class="btn btn-light btn-lg rounded-0 px-5 py-3 text-uppercase fw-bold" style="letter-spacing: 1px; font-size: 0.9rem;">
                Mua Sắm Ngay
            </a>
            <a href="#featured" class="btn btn-outline-light btn-lg rounded-0 px-5 py-3 text-uppercase fw-bold" style="letter-spacing: 1px; font-size: 0.9rem;">
                Khuyến Mãi
            </a>
        </div>
    </div>
</header>

<div class="container my-5 pb-4" id="categories">
    <!-- Highlight Statistics Section -->
    <div class="row g-4 mb-5 pb-5 border-bottom border-light">
        <div class="col-6 col-md-3">
            <div class="text-center">
                <h2 class="display-4 fw-black text-danger mb-0">10k+</h2>
                <p class="text-muted fw-bold small text-uppercase letter-spacing-1">Sản phẩm</p>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="text-center">
                <h2 class="display-4 fw-black text-primary mb-0">50+</h2>
                <p class="text-muted fw-bold small text-uppercase letter-spacing-1">Thương hiệu</p>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="text-center">
                <h2 class="display-4 fw-black text-warning mb-0">24/7</h2>
                <p class="text-muted fw-bold small text-uppercase letter-spacing-1">Hỗ trợ kỹ thuật</p>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="text-center">
                <h2 class="display-4 fw-black text-success mb-0">99%</h2>
                <p class="text-muted fw-bold small text-uppercase letter-spacing-1">Khách hàng hài lòng</p>
            </div>
        </div>
    </div>

    <!-- Categories Section -->
    <div class="text-center mb-5">
        <span class="text-danger fw-bold letter-spacing-1 small text-uppercase">TÌm kiếm nhanh chóng</span>
        <h2 class="fw-black mb-3 display-6 mt-2">DANH MỤC PHỔ BIẾN</h2>
        <div class="mx-auto bg-danger" style="height: 4px; width: 60px; border-radius: 2px;"></div>
    </div>

    <div class="row g-4 mb-5 pb-4">
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm rounded-4 text-center p-4 hover-lift bg-white h-100 d-flex flex-column justify-content-center">
                <div class="icon-box bg-danger bg-opacity-10 text-danger rounded-circle mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                    <i class="fas fa-tire fa-2x"></i>
                </div>
                <h5 class="fw-bold mb-1">Lốp Xe & Mâm</h5>
                <p class="small text-muted mb-0">Michelin, Bridgestone...</p>
                <a href="/PublicProduct?category=1" class="stretched-link"></a>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm rounded-4 text-center p-4 hover-lift bg-white h-100 d-flex flex-column justify-content-center">
                <div class="icon-box bg-primary bg-opacity-10 text-primary rounded-circle mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                    <i class="fas fa-oil-can fa-2x"></i>
                </div>
                <h5 class="fw-bold mb-1">Dầu Nhớt & Phụ gia</h5>
                <p class="small text-muted mb-0">Castrol, Motul, Mobil...</p>
                <a href="/PublicProduct?category=2" class="stretched-link"></a>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm rounded-4 text-center p-4 hover-lift bg-white h-100 d-flex flex-column justify-content-center">
                <div class="icon-box bg-warning bg-opacity-10 text-warning rounded-circle mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                    <i class="fas fa-car-battery fa-2x"></i>
                </div>
                <h5 class="fw-bold mb-1">Ắc Quy & Điện</h5>
                <p class="small text-muted mb-0">GS, Varta, Đồng Nai...</p>
                <a href="/PublicProduct?category=3" class="stretched-link"></a>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm rounded-4 text-center p-4 hover-lift bg-white h-100 d-flex flex-column justify-content-center">
                <div class="icon-box bg-info bg-opacity-10 text-info rounded-circle mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                    <i class="fas fa-lightbulb fa-2x"></i>
                </div>
                <h5 class="fw-bold mb-1">Đèn Xe & Phụ kiện</h5>
                <p class="small text-muted mb-0">Philips, Osram...</p>
                <a href="/PublicProduct?category=5" class="stretched-link"></a>
            </div>
        </div>
    </div>

    <!-- Top Brands Section -->
    <div class="py-5 bg-light rounded-5 p-4 mb-5 text-center px-md-5">
        <h5 class="fw-bold text-muted mb-4 text-uppercase letter-spacing-1">ĐỐI TÁC THƯƠNG HIỆU HÀNG ĐẦU</h5>
        <div class="d-flex flex-wrap justify-content-center align-items-center gap-4 gap-md-5 opacity-75 grayscale-hover">
            <h3 class="fw-black text-secondary m-0"><i class="fab fa-honda me-2"></i>HONDA</h3>
            <h3 class="fw-black text-secondary m-0"><i class="fas fa-car me-2"></i>TOYOTA</h3>
            <h3 class="fw-black text-secondary m-0">YAMAHA</h3>
            <h3 class="fw-black text-secondary m-0">MICHELIN</h3>
            <h3 class="fw-black text-secondary m-0">CASTROL</h3>
        </div>
    </div>

    <!-- Featured Products Section -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-5 pt-4" id="featured">
        <div class="mb-3 mb-md-0">
            <span class="text-danger fw-bold letter-spacing-1 small text-uppercase">Bộ sưu tập mới</span>
            <h2 class="fw-black mb-0 display-6 mt-2">SẢN PHẨM MỚI NHẤT</h2>
            <p class="text-muted m-0 mt-2">Cập nhật những mẫu mã mới nhất dành cho ô tô & xe máy với giá ưu đãi</p>
        </div>
        <a href="/PublicProduct" class="btn btn-outline-dark rounded-pill px-4 py-2 fw-bold btn-hover-scale">
            XEM TẤT CẢ <i class="fas fa-chevron-right ms-2 small"></i>
        </a>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var product in Model.Take(8))
            {
                <div class="col-md-4 col-lg-3">
                    <div class="card product-card border-0 shadow-sm h-100 rounded-4 overflow-hidden position-relative group-hover">
                        <!-- Badge -->
                        @if (product.IsHot || product.ProductId % 3 == 0)
                        {
                            <div class="position-absolute top-0 start-0 m-3 z-index-3">
                                <span class="badge bg-danger rounded-pill px-3 py-2 fw-bold shadow-sm">MỚI</span>
                            </div>
                        }
                        
                        <!-- Quick actions -->
                        <div class="position-absolute top-0 end-0 m-3 z-index-3 quick-actions opacity-0 transition-all">
                            <form asp-controller="Wishlist" asp-action="Toggle" asp-route-id="@product.ProductId" method="post" class="d-inline">
                                <button type="submit" class="btn btn-light text-danger rounded-circle shadow-sm mb-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                    <i class="far fa-heart"></i>
                                </button>
                            </form>
                        </div>

                        <!-- Image -->
                        <div class="product-img-container bg-light position-relative overflow-hidden" style="height: 220px; padding: 0;">
                            <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "https://images.unsplash.com/photo-1541443131876-44b035dd1c51?q=80" : product.ImageUrl)" 
                                 class="card-img-top h-100 w-100 object-fit-cover transition-transform duration-500 hover-scale-img" 
                                 alt="@product.Name" style="object-fit: cover; object-position: center;">
                            
                            <!-- Overlay CTA -->
                            <div class="position-absolute bottom-0 start-0 w-100 p-3 overlay-cta transform-translate-y-100 transition-all z-index-2">
                                <form asp-controller="Cart" asp-action="Add" method="post">
                                    <input type="hidden" name="id" value="@product.ProductId" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <button type="submit" class="btn btn-danger w-100 rounded-pill fw-bold shadow-sm py-2">
                                        THÊM VÀO GIỎ <i class="fas fa-cart-plus ms-1"></i>
                                    </button>
                                </form>
                            </div>
                        </div>

                        <!-- Info -->
                        <div class="card-body p-4 d-flex flex-column bg-white">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="badge bg-secondary bg-opacity-10 text-dark border-0 small px-2 py-1">@(product.Category?.Name ?? "Phụ tùng")</span>
                                <div class="text-warning small">
                                    <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i>
                                </div>
                            </div>
                            <h5 class="card-title fw-bold mb-3">
                                <a href="/PublicProduct/Details/@product.ProductId" class="text-dark text-decoration-none hover-text-danger line-clamp-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">
                                    @product.Name
                                </a>
                            </h5>
                            
                            <div class="mt-auto d-flex align-items-end justify-content-between">
                                <div>
                                    <div class="text-muted small text-decoration-line-through mb-1">@((product.Price * 1.1m).ToString("N0")) đ</div>
                                    <h4 class="text-danger fw-black m-0 mb-0">@product.Price.ToString("N0") <span class="fs-6 fw-normal">đ</span></h4>
                                </div>
                                <a href="/PublicProduct/Details/@product.ProductId" class="btn btn-outline-dark rounded-circle d-flex align-items-center justify-content-center border-2 btn-hover-danger" style="width: 45px; height: 45px;">
                                    <i class="fas fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Testimonials Section -->
    @{
        var reviews = ViewBag.Reviews as IEnumerable<SparePartsManagement.Models.Review>;
    }
    @if (reviews != null && reviews.Any())
    {
        <div class="mt-5 pt-5 mb-5 pb-4">
            <div class="text-center mb-5">
                <span class="text-danger fw-bold letter-spacing-1 small text-uppercase">Phản hồi thực tế</span>
                <h2 class="fw-black mb-3 display-6 mt-2">KHÁCH HÀNG NÓI GÌ</h2>
                <div class="mx-auto bg-danger" style="height: 4px; width: 60px; border-radius: 2px;"></div>
            </div>
            
            <div class="row g-4">
                @{
                    var colors = new[] { "primary", "success", "danger", "info", "warning" };
                    int index = 0;
                }
                @foreach (var review in reviews)
                {
                    var userName = review.UserEmail.Split('@')[0];
                    var avatarInit = userName.Substring(0, 1).ToUpper();
                    var isDarkCard = index % 3 == 2;
                    var cName = colors[index % colors.Length];
                    
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm rounded-4 p-4 h-100 @(isDarkCard ? "bg-dark text-white" : "bg-white") hover-lift position-relative">
                            <i class="fas fa-quote-left fa-3x @(isDarkCard ? "text-white opacity-10" : "text-light opacity-50") position-absolute top-0 start-0 m-3 z-index-0"></i>
                            <div class="position-relative z-index-2 d-flex flex-column h-100">
                                <div class="d-flex text-warning mb-3 small">
                                    @for (int s = 1; s <= 5; s++)
                                    {
                                        <i class="fas fa-star @(s > review.StarRating ? "text-muted opacity-50" : "")"></i>
                                    }
                                </div>
                                <p class="@(isDarkCard ? "text-white-50" : "text-muted") fst-italic mb-4">"@review.Comment"</p>
                                <div class="d-flex align-items-center gap-3 mt-auto">
                                    <div class="bg-@cName text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 45px; height: 45px;">
                                        @avatarInit
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-0 @(isDarkCard ? "text-white" : "")">@userName</h6>
                                        <small class="@(isDarkCard ? "text-white-50" : "text-muted")">Đã mua: @(review.Product?.Name ?? "Sản phẩm")</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    index++;
                }
            </div>
        </div>
    }

    <!-- Newsletter / CTA Bottom -->
    <div class="mt-5 pt-2">
        <div class="bg-dark rounded-5 p-5 text-center text-white position-relative overflow-hidden shadow-lg">
            <!-- decorative circles -->
            <div class="position-absolute top-0 start-0 translate-middle w-50 h-50 bg-danger rounded-circle opacity-25" style="filter: blur(50px);"></div>
            <div class="position-absolute bottom-0 end-0 translate-middle w-50 h-50 bg-primary rounded-circle opacity-25" style="filter: blur(50px);"></div>
            
            <div class="position-relative z-index-2 py-md-4 max-w-lg mx-auto" style="max-width: 600px;">
                <h2 class="display-6 fw-black mb-3">ĐĂNG KÝ NHẬN TIN KHUYẾN MÃI</h2>
                <p class="text-white-50 mb-4">Nhận thông báo sớm nhất về các đợt giảm giá, ưu đãi đặc biệt và sản phẩm mới.</p>
                <form class="d-flex gap-2 p-2 bg-white bg-opacity-10 rounded-pill backdrop-blur border border-light border-opacity-25">
                    <input type="email" class="form-control bg-transparent border-0 text-white shadow-none px-4" placeholder="Nhập email của bạn..." required>
                    <button type="button" class="btn btn-danger rounded-pill px-4 fw-bold whitespace-nowrap" style="white-space: nowrap;">ĐĂNG KÝ</button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
/* Utilities & Base Styles */
.fw-black { font-weight: 900; }
.letter-spacing-1 { letter-spacing: 1px; }
.bg-gradient-danger { background: linear-gradient(135deg, #dc3545 0%, #ffc107 100%); }
.bg-clip-text { -webkit-background-clip: text; background-clip: text; }
.text-transparent { color: transparent; }
.backdrop-blur { backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); }

/* Buttons & Hover Effects */
.btn-hover-scale { transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1); }
.btn-hover-scale:hover { transform: translateY(-3px) scale(1.02); }
.shadow-danger-lg { box-shadow: 0 10px 25px -5px rgba(220, 53, 69, 0.4); }

.hover-lift { transition: all 0.3s ease; }
.hover-lift:hover { transform: translateY(-10px); box-shadow: 0 15px 30px rgba(0,0,0,0.08) !important; }

.hover-text-danger:hover { color: #dc3545 !important; }

/* Product Card Customizations */
.product-card { transition: all 0.3s ease; border: 1px solid rgba(0,0,0,0.05) !important; }
.product-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(0,0,0,0.1) !important; border-color: rgba(0,0,0,0) !important; }

.transition-transform { transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1); }
.product-card:hover .hover-scale-img { transform: scale(1.08); }

.transition-all { transition: all 0.3s ease; }
.group-hover:hover .quick-actions { opacity: 1; }

.transform-translate-y-100 { transform: translateY(100%); }
.group-hover:hover .overlay-cta { transform: translateY(0); }

.btn-hover-danger:hover { background-color: #dc3545; border-color: #dc3545; color: white !important; }

/* Grayscale logos hover */
.grayscale-hover > * { transition: all 0.3s ease; filter: grayscale(100%); opacity: 0.7; }
.grayscale-hover > *:hover { filter: grayscale(0%); opacity: 1; color: #dc3545 !important; transform: scale(1.1); }

/* Animation Classes */
@@keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
    100% { transform: translateY(0px); }
}
.hero-section .img-fluid { animation: float 6s ease-in-out infinite; }
</style>
