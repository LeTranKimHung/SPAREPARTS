@{
    ViewData["Title"] = "Liên hệ";
}

<header class="position-relative d-flex align-items-center justify-content-center text-center overflow-hidden" style="min-height: 40vh; background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1596401057633-54a8fea6eb21?q=80&w=2000&auto=format&fit=crop'); background-size: cover; background-position: center; background-attachment: fixed; color: #fff;">
    <div class="container px-4 z-index-2 position-relative" style="padding-top: 80px;">
        <h1 class="display-4 fw-black mb-3 text-uppercase" style="letter-spacing: -1px; font-weight: 900;">
            KẾT NỐI VỚI CHÚNG TÔI
        </h1>
        <p class="lead mx-auto text-white-50" style="max-width: 600px; font-weight: 400;">
            Hỗ trợ 24/7. Yêu cầu báo giá, tư vấn phụ tùng. Đội ngũ chuyên gia luôn sẵn sàng.
        </p>
    </div>
</header>

<div class="container my-5 py-5">
    <div class="row g-5">
        <!-- Contact Info -->
        <div class="col-lg-5">
            <span class="text-danger fw-bold letter-spacing-1 small text-uppercase">Trung tâm hỗ trợ</span>
            <h2 class="fw-black mb-4 mt-2 display-6 text-dark">THÔNG TIN LIÊN HỆ</h2>
            <div class="bg-danger mb-5" style="height: 4px; width: 60px; border-radius: 2px;"></div>
            
            <p class="text-muted mb-5">Nếu bạn gặp bất kỳ vấn đề gì về đơn hàng, hay không biết chọn phụ tùng nào phù hợp cho xe của mình, hãy liên hệ ngay cho bộ phận CSKH nhé.</p>
            
            <div class="d-flex align-items-start mb-4 bg-light rounded-4 p-4 hover-lift transition-all">
                <i class="fas fa-map-marker-alt fa-2x text-danger me-4 mt-1"></i>
                <div>
                    <h5 class="fw-bold text-dark mb-1">Trụ sở chính</h5>
                    <p class="text-muted m-0">123 Đường Láng, Đống Đa, Hà Nội, Việt Nam.</p>
                </div>
            </div>
            
            <div class="d-flex align-items-start mb-4 bg-light rounded-4 p-4 hover-lift transition-all">
                <i class="fas fa-phone-alt fa-2x text-primary me-4 mt-1"></i>
                <div>
                    <h5 class="fw-bold text-dark mb-1">Điện thoại Hotline</h5>
                    <p class="text-muted m-0">Zalo/Call: +84 0987.654.321</p>
                    <p class="text-muted m-0 small">Phục vụ T2 - CN (08:00 - 18:00)</p>
                </div>
            </div>
            
            <div class="d-flex align-items-start mb-4 bg-light rounded-4 p-4 hover-lift transition-all">
                <i class="fas fa-envelope fa-2x text-success me-4 mt-1"></i>
                <div>
                    <h5 class="fw-bold text-dark mb-1">Hòm thư Điện tử</h5>
                    <p class="text-muted m-0">Email: support@spareparts.vn</p>
                    <p class="text-muted m-0 small">Báo giá Đại Lý: b2b@spareparts.vn</p>
                </div>
            </div>
        </div>
        
        <!-- Contact Form -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-lg rounded-5 p-5 bg-white h-100 position-relative overflow-hidden">
                <div class="position-absolute top-0 end-0 translate-middle-y mt-0 me-n4 bg-danger bg-opacity-10 rounded-circle" style="width: 200px; height: 200px; filter: blur(40px);"></div>
                <h3 class="fw-bold text-dark mb-4 position-relative z-index-2">Gửi Tin Nhắn Cho Chúng Tôi</h3>
                <form class="position-relative z-index-2">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label text-muted fw-bold small">Họ và tên *</label>
                            <input type="text" class="form-control bg-light border-0 shadow-none px-4 py-3 rounded-3" placeholder="Nguyễn Văn A" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted fw-bold small">Số điện thoại *</label>
                            <input type="tel" class="form-control bg-light border-0 shadow-none px-4 py-3 rounded-3" placeholder="0987xxx" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-muted fw-bold small">Tiêu đề / Chủ đề hỗ trợ *</label>
                            <input type="text" class="form-control bg-light border-0 shadow-none px-4 py-3 rounded-3" placeholder="Ví dụ: Cần tư vấn chọn ắc quy xe Vios" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-muted fw-bold small">Nội dung chi tiết *</label>
                            <textarea class="form-control bg-light border-0 shadow-none px-4 py-3 rounded-3" rows="5" placeholder="Bạn muốn hỏi gì..." required></textarea>
                        </div>
                        <div class="col-12 mt-4 text-end">
                            <button type="button" class="btn btn-dark btn-lg rounded-pill px-5 fw-bold w-100 hover-lift shadow-lg">GỬI YÊU CẦU NGAY</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
