@model SparePartsManagement.Models.Order

@{
    ViewData["Title"] = "Thanh toán đơn hàng";
}

<div class="container my-5 py-5">
    <div class="row align-items-center mb-5">
        <div class="col">
            <h2 class="fw-bold m-0 text-center"><i class="fas fa-credit-card text-danger me-3"></i>XÁC NHẬN THANH TOÁN</h2>
            <p class="text-muted small mt-2 text-center">Vui lòng điền thông tin người nhận để chúng tôi giao hàng sớm nhất</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-body p-5">
                    <form asp-action="Checkout" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4 small"></div>

                        <div class="mb-4">
                            <label asp-for="CustomerName" class="form-label fw-bold small text-muted text-uppercase">Tên người nhận <span class="text-danger">*</span></label>
                            <input asp-for="CustomerName" class="form-control border-0 bg-light py-3 px-4 rounded-3 shadow-none" placeholder="Nhập họ và tên...">
                            <span asp-validation-for="CustomerName" class="text-danger small"></span>
                        </div>

                        <div class="row g-4">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Email" class="form-label fw-bold small text-muted text-uppercase">Email liên hệ <span class="text-danger">*</span></label>
                                <input asp-for="Email" class="form-control border-0 bg-light py-3 px-4 rounded-3 shadow-none" placeholder="name@example.com">
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label asp-for="Phone" class="form-label fw-bold small text-muted text-uppercase">Số điện thoại <span class="text-danger">*</span></label>
                                <input asp-for="Phone" class="form-control border-0 bg-light py-3 px-4 rounded-3 shadow-none" placeholder="09xxxxxxxx">
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-5 pb-4 border-bottom">
                            <label asp-for="ShippingAddress" class="form-label fw-bold small text-muted text-uppercase">Địa chỉ nhà cụ thể <span class="text-danger">*</span></label>
                            <textarea asp-for="ShippingAddress" id="ShippingAddressInput" class="form-control border-0 bg-light py-3 px-4 rounded-3 shadow-none" rows="3" placeholder="Ví dụ: 123 Lê Lợi, Quận 1, Hồ Chí Minh..." required></textarea>
                            <span asp-validation-for="ShippingAddress" class="text-danger small"></span>
                            <div class="form-text text-muted mt-2"><i class="fas fa-magic me-1"></i>Hệ thống sẽ tự nhận diện Tỉnh/Khu vực của bạn trong ô địa chỉ để tính phí!</div>
                        </div>

                        <div class="row mb-5 pb-4 border-bottom align-items-start">
                            <div class="col-md-7">
                                <p class="text-muted mb-3 small fw-bold">CHỌN PHƯƠNG THỨC THANH TOÁN:</p>
                                
                                <label class="d-flex align-items-start p-3 mb-3 bg-light rounded-3 border w-100 hover-lift" style="cursor: pointer; transition: all 0.2s;">
                                    <div class="pt-1">
                                        <input class="form-check-input m-0 shadow-none border-secondary" style="width: 20px; height: 20px;" type="radio" name="paymentMethod" id="paymentCOD" value="COD" checked>
                                    </div>
                                    <div class="ms-3 flex-grow-1">
                                        <span class="fw-bold text-dark d-block mb-1"><i class="fas fa-hand-holding-usd me-2 text-success"></i>Thanh toán khi nhận hàng (COD)</span>
                                        <div class="text-muted small fw-normal lh-sm">Nhận hàng rồi mới thanh toán tiền mặt cho Shipper</div>
                                    </div>
                                </label>

                                <label class="d-flex align-items-start p-3 bg-light rounded-3 border w-100 hover-lift" style="cursor: pointer; transition: all 0.2s; border-color: #004285 !important;">
                                    <div class="pt-1">
                                        <input class="form-check-input m-0 shadow-none border-primary" style="width: 20px; height: 20px;" type="radio" name="paymentMethod" id="paymentVNPAY" value="VNPAY">
                                    </div>
                                    <div class="ms-3 flex-grow-1">
                                        <span class="fw-bold d-block mb-1" style="color: #004285;"><i class="fas fa-wallet me-2"></i>Thanh toán qua Ví VNPAY / Thẻ ATM</span>
                                        <div class="text-muted small fw-normal lh-sm">Quét mã QR qua ứng dụng ngân hàng hoặc cổng VNPAY</div>
                                    </div>
                                </label>
                            </div>

                            <div class="col-md-5 mt-4 mt-md-0">
                                <p class="text-muted mb-3 small fw-bold">THÔNG TIN ĐƠN HÀNG:</p>
                                <div class="bg-light p-4 rounded-4 border border-1 border-secondary border-opacity-10 shadow-sm">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="text-muted small">Tạm tính:</span>
                                        <span class="text-dark fw-bold" id="lblSubtotal" data-value="@ViewBag.Subtotal">@(((decimal)ViewBag.Subtotal).ToString("N0")) đ</span>
                                    </div>
                                    
                                    @if ((decimal)ViewBag.Discount > 0)
                                    {
                                        <div class="d-flex justify-content-between align-items-center mb-2 text-success">
                                            <span class="small">Giảm giá (@ViewBag.Discount%):</span>
                                            <span class="fw-bold" id="lblDiscount" data-value="@ViewBag.DiscountAmount">- @(((decimal)ViewBag.DiscountAmount).ToString("N0")) đ</span>
                                        </div>
                                    }
                                    
                                    <div class="d-flex justify-content-between align-items-center mb-3 text-info">
                                        <span class="small">Phí vận chuyển:</span>
                                        <span class="fw-bold" id="lblShippingFee">0 đ</span>
                                    </div>
                                    
                                    <div class="d-flex justify-content-between align-items-center pt-3 border-top border-secondary border-opacity-25 mt-2">
                                        <span class="fw-bold text-dark">TỔNG TIỀN:</span>
                                        <span class="fw-black fs-4 text-danger m-0" id="lblTotalAmount">@Model.TotalAmount.ToString("N0") đ</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Trường ẩn để gửi phí ship lên backend -->
                        <input type="hidden" name="shippingFee" id="hiddenShippingFee" value="@(ViewBag.ShippingFee ?? 0)" />

                        <script>
                            document.addEventListener("DOMContentLoaded", function () {
                                const addressInput = document.getElementById("ShippingAddressInput");
                                const lblShippingFee = document.getElementById("lblShippingFee");
                                const lblTotalAmount = document.getElementById("lblTotalAmount");
                                const hiddenShippingFee = document.getElementById("hiddenShippingFee");

                                // Base amount calculation
                                const subtotal = parseFloat(document.getElementById("lblSubtotal").getAttribute("data-value"));
                                const discountElement = document.getElementById("lblDiscount");
                                const discountAmount = discountElement ? parseFloat(discountElement.getAttribute("data-value")) : 0;
                                const originalTotal = subtotal - discountAmount;

                                function updateShippingFee() {
                                    let val = addressInput.value.toLowerCase().trim();
                                    let fee = 0;
                                    
                                    if (val === "") {
                                        fee = 0;
                                    }
                                    else if (val.includes("hcm") || val.includes("hồ chí minh") || val.includes("ho chi minh") || val.includes("bình dương") || val.includes("binh duong") || val.includes("đồng nai") || val.includes("dong nai")) {
                                        fee = 0;
                                    } 
                                    else if (val.includes("long an") || val.includes("tiền giang") || val.includes("tien giang") || val.includes("tây ninh") || val.includes("tay ninh") || val.includes("vũng tàu") || val.includes("vung tau") || val.includes("bà rịa") || val.includes("ba ria")) {
                                        fee = 10000;
                                    }
                                    else if (val.includes("cần thơ") || val.includes("can tho") || val.includes("bến tre") || val.includes("ben tre") || val.includes("vĩnh long") || val.includes("vinh long") || val.includes("bình thuận") || val.includes("binh thuan") || val.includes("bình phước") || val.includes("binh phuoc") || val.includes("đồng tháp") || val.includes("dong thap")) {
                                        fee = 15000;
                                    } 
                                    else {
                                        fee = 20000;
                                    }
                                    
                                    // Update hidden field for POST
                                    hiddenShippingFee.value = fee;
                                    
                                    // Update labels
                                    lblShippingFee.innerText = (fee > 0 ? "+ " : "") + new Intl.NumberFormat('vi-VN').format(fee) + " đ";
                                    const finalTotal = originalTotal + fee;
                                    lblTotalAmount.innerText = new Intl.NumberFormat('vi-VN').format(finalTotal) + " đ";
                                }

                                addressInput.addEventListener("input", updateShippingFee);

                                // Nếu có sẵn địa chỉ (khi validation lỗi hoặc được điền trước), tự chạy update
                                if (addressInput.value.trim() !== "") {
                                    updateShippingFee();
                                }
                            });
                        </script>

                        <div class="pt-2 text-center">
                             <button type="submit" class="btn btn-danger w-100 rounded-pill py-3 fw-bold shadow-lg mb-3">
                                XÁC NHẬN ĐẶT HÀNG <i class="fas fa-check-circle ms-2"></i>
                            </button>
                            <p class="text-muted small m-0"><i class="fas fa-shield-alt me-1 text-success"></i>Bảo mật thông tin khách hàng tuyệt đối</p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
